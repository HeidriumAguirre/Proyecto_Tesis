# ================================================================
# Plantilla de variables de entorno para el ITS RAG Math
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.
# ================================================================

# --- Google Gemini (obligatorio) ---------------------------------
# Genera tu API key en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...TU_API_KEY_AQUI

# --- MySQL (usado por docker-compose y por la app) ---------------
MYSQL_ROOT_PASSWORD=demo
MYSQL_DATABASE=its_murialdo
MYSQL_PORT=3306
# Nombre del servicio MySQL dentro de la red de docker-compose
# (NO usar host.docker.internal: la app corre dentro del compose)
MYSQL_HOST=db_relacional
MYSQL_USER=root

# --- Streamlit / TLS ---------------------------------------------
# Dominios para los que se emitió el certificado autofirmado
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
